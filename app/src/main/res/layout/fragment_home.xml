<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="36dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Willkommen!"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvWeightLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Aktuelles Gewicht"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvCurrentWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="-- kg"
            android:textSize="64sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWeightLabel" />

        <TextView
            android:id="@+id/tvLastWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Letztes Gewicht: -- kg"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentWeight"
            app:layout_constraintStart_toStartOf="parent"/>


        <Button
            android:id="@+id/btnUpdateWeight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Gewicht aktualisieren"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/tvLastWeight"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvWorkoutLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Heutiges Workout"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/btnUpdateWeight"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Heutiges Workout Text -->
        <TextView
            android:id="@+id/tvTodayWorkout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Kein Workout geplant"
            android:textSize="18sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvWorkoutLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnShowPlannedWorkout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Geplantes Workout anzeigen"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvTodayWorkout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnStartSession"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Session starten"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnShowPlannedWorkout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnAddWorkout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Workout hinzufügen"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnStartSession"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>